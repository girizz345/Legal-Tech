# Postgres
POSTGRES_USER=legaltech
POSTGRES_PASSWORD=legaltech_dev_password
POSTGRES_DB=legaltech
POSTGRES_PORT=5432
DATABASE_URL=postgresql://legaltech:legaltech_dev_password@localhost:5432/legaltech

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO (S3-compatible)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=localhost:9000
MINIO_BUCKET=legal-tech-docs
MINIO_USE_SSL=false

# Auth
JWT_SECRET=change_me_dev_secret_please
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# LLM (clause-variant classification only — never free-drafts contract text)
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
LLM_TIMEOUT_SECONDS=20
